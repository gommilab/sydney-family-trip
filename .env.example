# =================================================================
# 환경변수 템플릿
# 이 파일을 복사해서 .env.local 로 저장한 뒤 실제 값을 채워주세요.
# .env.local 은 .gitignore 에 포함되어 git 에 커밋되지 않습니다.
# =================================================================

# --- AI 질문하기 (필수) ---
# OpenAI API 키. https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=sk-...

# 사용할 모델 (선택). 미설정 시 gpt-4o-mini 사용.
# OPENAI_MODEL=gpt-4o-mini


# --- 호텔 예약 개인정보 (선택) -----------------------------------
# 이 값들이 비어 있어도 앱은 정상 동작합니다. 비워두면 호텔정보
# 화면에서 해당 행이 자동으로 숨겨지고, AI 응답에서도 생략됩니다.
#
# VITE_ 프리픽스가 있는 변수는 클라이언트 번들에 인라인되어
# 배포된 앱에서 가족이 볼 수 있게 됩니다 (UI 표시 목적).
# 이는 git 에 커밋되지 않는 한 안전합니다.
# -----------------------------------------------------------------

# 예약자 이름 (영문, 여권 동일)
VITE_HOTEL_GUEST_NAME=
# Agoda 회원 ID
VITE_HOTEL_MEMBER_ID=
# Agoda 예약 번호 (Booking ID)
VITE_HOTEL_AGODA_BOOKING_ID=
# 예약 참조 번호 (Booking.com booking ID)
VITE_HOTEL_REFERENCE_NO=
# 총 결제 예정 금액 (예: "AUD 1,234.00")
VITE_HOTEL_TOTAL_AMOUNT=
